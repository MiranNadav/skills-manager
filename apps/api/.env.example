# Copy to apps/api/.env and fill in your values

PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173
# Defaults to ~/.agents/skills if not set
SKILLS_PATH=

# AI Provider: "claude" or "gemini"
AI_PROVIDER=claude

# Required if AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Required if AI_PROVIDER=gemini
GEMINI_API_KEY=AIza...

# Model overrides (optional — defaults shown)
AI_MODEL_CLAUDE=claude-sonnet-4-6
AI_MODEL_GEMINI=gemini-2.0-flash
