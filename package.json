{
  "name": "skills-manager",
  "private": true,
  "version": "0.0.0",
  "description": "Skills Manager — browse, edit, and AI-analyze your Claude agent skills",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r --filter \"./apps/**\" dev",
    "dev:api": "pnpm --filter @skills-manager/api dev",
    "dev:web": "pnpm --filter @skills-manager/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint apps/api/src apps/web/src",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "typescript-eslint": "^8.59.3"
  }
}
